# 本機路徑設定（範例）
# 請複製為 .agent/env/pa-local.env 並填入你自己的路徑

# Steam library 根目錄
PA_STEAM_LIBRARY_ROOT=<SteamLibraryPath>

# PA TITANS 安裝路徑
PA_GAME_DIR=<PAInstallPath>

# 可選：若未填，腳本會用 PA_GAME_DIR\media
PA_MEDIA_DIR=<PAMediaPath>

# PA 使用者資料根目錄（含 client_mods/server_mods）
PA_DATA_DIR=<PADataPath>

# 可選：若未填，腳本會用 PA_DATA_DIR\client_mods
PA_CLIENT_MODS_DIR=<PAClientModsPath>

# 可選：若未填，腳本會用 PA_DATA_DIR\server_mods
PA_SERVER_MODS_DIR=<PAServerModsPath>
